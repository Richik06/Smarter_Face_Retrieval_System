# Storage
EVENT_DATA_DIR=event_data

# Face detection (retinaface | mtcnn | opencv)
DETECTOR_BACKEND=retinaface

# Embedding model (Facenet512 | ArcFace)
EMBEDDING_MODEL=Facenet512
EMBEDDING_DIM=512

# DBSCAN clustering
DBSCAN_EPS=0.28
DBSCAN_MIN_SAMPLES=1
DBSCAN_METRIC=cosine

# Similarity threshold
SIMILARITY_THRESHOLD=0.75

# FAISS
USE_FAISS=true
FAISS_DEVICE=cpu
FAISS_GPU_ID=0
FAISS_IVF_THRESHOLD=100
FAISS_NLIST=10
FAISS_NPROBE=10

# Google Drive
GOOGLE_DRIVE_API_KEY=
DRIVE_TEMP_DIR=event_data/_drive_tmp
DRIVE_MAX_IMAGES=0

# Cloudinary (optional - for cloud image storage)
CLOUDINARY_CLOUD_NAME=demo-cloud
CLOUDINARY_API_KEY=1234567890
CLOUDINARY_API_SECRET=abcdefg
CLOUDINARY_UPLOAD_FOLDER=face-retrieval

# Logging
LOG_LEVEL=INFO