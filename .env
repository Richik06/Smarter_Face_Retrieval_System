# Storage
EVENT_DATA_DIR=event_data

# Face detection
DETECTOR_BACKEND=retinaface

# Embedding model
EMBEDDING_MODEL=Facenet512
EMBEDDING_DIM=512

# DBSCAN clustering
DBSCAN_EPS=0.35
DBSCAN_MIN_SAMPLES=1
DBSCAN_METRIC=cosine

# Similarity threshold
SIMILARITY_THRESHOLD=0.55

# FAISS
USE_FAISS=true

# Logging
LOG_LEVEL=INFO